{
    "servers": {
        "io.github.ChromeDevTools/chrome-devtools-mcp": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "chrome-devtools-mcp@latest"
            ]
        },
        "microsoft/playwright-mcp": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "@playwright/mcp@latest"
            ]
        },
        "cloudflare": {
            "command": "npx",
            "args": [
                "mcp-remote",
                "https://docs.mcp.cloudflare.com/mcp"
            ]
        }
    }
}